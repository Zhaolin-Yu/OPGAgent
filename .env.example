# Copy to .env and fill in real values, or export them as environment variables.
# LangSmith tracing is enabled by default; use --no-langsmith to disable.

# OpenAI (main Agent LLM — required in both profiles)
OPENAI_API_KEY=your-openai-api-key

# Cloud profile only
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=opgagent

# Profile: cloud (default) or local
# cloud -> GPT + Gemini + Claude + Tool + RAG
# local -> GPT + DentalGPT + OralGPT + Tool + RAG
OPG_PROFILE=cloud
